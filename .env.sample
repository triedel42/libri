# Allowed host for Vite's dev server (server.allowedHosts).
HOST=

# 42 OAuth application credentials (create one at profile.intra.42.fr/oauth/applications).
# The redirect URI is derived automatically from HOST: https://{HOST}/api/auth/callback
# (falls back to http://localhost:8000/api/auth/callback when HOST is unset).
INTRA_CLIENT_ID=
INTRA_CLIENT_SECRET=

# Secret used to sign session cookies — generate with: openssl rand -hex 32
JWT_SECRET=
